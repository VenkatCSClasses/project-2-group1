erDiagram
    user_group ||--o{ group_member : "has members"
    user_account ||--o{ group_member : "acts as"
    user_group ||--o{ shared_vault_item : "contains"
    shared_vault_item ||--o{ user_vault_access : "is encrypted into"
    user_account ||--o{ user_vault_access : "decrypts"

    user_group {
        integer group_id PK
        string group_name
        timestamp created_at
        timestamp updated_at
        binary group_code_salt
        binary group_code_hash
    }

    user_account {
        integer user_id PK
        string username UK
        text public_key
        timestamp created_at
        timestamp updated_at
        binary password_salt
        binary password_hash
    } %% Secret key is generated from password

    group_member {
        integer user_id PK,FK
        integer group_id PK,FK
        string role
        timestamp created_at
        timestamp updated_at
    }

    shared_vault_item {
        integer item_id PK
        integer group_id FK
        string service_name
        string service_username
        timestamp created_at
        timestamp updated_at
    }

    user_vault_access {
        integer user_id PK,FK
        integer item_id PK,FK
        binary encrypted_service_password
        timestamp created_at
        timestamp updated_at
    }
