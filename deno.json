{
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.14",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@types/pg": "npm:@types/pg@^8.20.0",
    "hono": "jsr:@hono/hono@^4.12.11",
    "knex": "npm:knex@^3.2.9",
    "libsql": "npm:libsql@^0.5.29",
    "pg": "npm:pg@^8.20.0"
  },
  "tasks": {
    "start": "deno run --allow-ffi --watch --allow-net --ignore-env --allow-read=. --allow-read=../../node_modules/ main.ts",
    "check": "deno fmt **/*.ts && IS_TEST=1 deno test --allow-sys --allow-ffi --allow-net --allow-env --allow-read=. tests/*.ts",
    "migrate": "deno run --allow-net --ignore-env --allow-read --allow-write migrate.ts"
  },
  "deploy": {
    "org": "comp345spr26team1",
    "app": "project-2-group1",
    "install": "deno install",
    "build": "deno task check",
    "runtime": {
      "entrypoint": "main.ts"
    }
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto",
  "allowScripts": [
    "npm:better-sqlite3@12.9.0",
    "npm:sqlite3@6.0.1"
  ]
}
